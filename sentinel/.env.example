# SENTINEL On-Prem Configuration
# Copy this file to .env and update the values before deploying.

# ---------- Database ----------
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=change-me-in-production

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- API ----------
API_PORT=8080
SENTINEL_SECRET=change-me-generate-random-secret
DATABASE_URL=postgresql://sentinel:change-me-in-production@postgres:5432/sentinel

# ---------- Dashboard ----------
DASHBOARD_PORT=3000
SENTINEL_API_URL=http://api:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-generate-random-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- GitHub App (optional) ----------
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ---------- S3 Archive (optional) ----------
S3_ARCHIVE_BUCKET=
S3_ARCHIVE_PREFIX=sentinel
S3_RETENTION_DAYS=2555
AWS_REGION=us-east-1

# ---------- KMS (optional) ----------
KMS_MASTER_KEY_ID=

# ---------- LLM Review (optional — only needed with --profile llm) ----------
ANTHROPIC_API_KEY=
LLM_TOKEN_BUDGET=50000
