{
  "name": "@sentinel/sentinel-lsp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sentinel-lsp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "compile": "bun build src/index.ts --compile --outfile dist/sentinel-lsp",
    "compile:linux": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/sentinel-lsp-linux-x64",
    "compile:darwin": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/sentinel-lsp-darwin-arm64",
    "compile:win": "bun build src/index.ts --compile --target=bun-windows-x64 --outfile dist/sentinel-lsp-win-x64.exe",
    "test": "vitest run",
    "lint": "echo 'lint placeholder'"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.0",
    "vscode-uri": "^3.0.0",
    "eventsource": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7",
    "vitest": "^3.0"
  }
}
