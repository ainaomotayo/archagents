{
  "dashboard": {
    "id": null,
    "uid": "sentinel-security-sso",
    "title": "Sentinel Security & SSO",
    "tags": ["sentinel"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "title": "Auth Overview",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "collapsed": false
      },
      {
        "title": "Auth Attempts/min",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
        "targets": [
          { "expr": "sum(rate(sentinel_api_sso_auth_attempts_total[5m]) * 60)", "legendFormat": "attempts/min" }
        ]
      },
      {
        "title": "Auth Success Rate",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
        "targets": [
          { "expr": "sum(rate(sentinel_api_sso_auth_attempts_total{result=\"success\"}[5m])) / sum(rate(sentinel_api_sso_auth_attempts_total[5m]))", "legendFormat": "success rate" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 0.9, "color": "yellow" }, { "value": 0.95, "color": "green" }] }
          }
        }
      },
      {
        "title": "Rate Limited Count",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
        "targets": [
          { "expr": "increase(sentinel_api_sso_auth_attempts_total{result=\"rate_limited\"}[1h])", "legendFormat": "rate limited (1h)" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 20, "color": "red" }] }
          }
        }
      },
      {
        "title": "Active Sessions",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
        "targets": [
          { "expr": "sum(sentinel_api_sso_auth_attempts_total{result=\"success\"}) - sum(sentinel_api_sso_auth_attempts_total{result=\"logout\"})", "legendFormat": "sessions" }
        ]
      },
      {
        "title": "SSO Providers",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
        "collapsed": false
      },
      {
        "title": "Auth Attempts by Provider",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          { "expr": "sum by (provider) (rate(sentinel_api_sso_auth_attempts_total[5m]))", "legendFormat": "{{ provider }}" }
        ]
      },
      {
        "title": "Failure Reasons",
        "type": "piechart",
        "datasource": "Prometheus",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [
          { "expr": "sum by (reason) (increase(sentinel_api_sso_auth_attempts_total{result=\"failure\"}[1h]))", "legendFormat": "{{ reason }}" }
        ]
      },
      {
        "title": "Audit Trail",
        "type": "row",
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
        "collapsed": false
      },
      {
        "title": "Audit Events by Action",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
        "targets": [
          { "expr": "sum by (action) (rate(sentinel_api_audit_events_total[5m]))", "legendFormat": "{{ action }}" }
        ]
      },
      {
        "title": "Top Actors",
        "type": "table",
        "datasource": "Prometheus",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
        "targets": [
          { "expr": "topk(10, sum by (actor) (increase(sentinel_api_audit_events_total[1h])))", "legendFormat": "{{ actor }}", "format": "table", "instant": true }
        ],
        "transformations": [
          { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "actor": "Actor", "Value": "Events (1h)" } } }
        ]
      }
    ]
  }
}
