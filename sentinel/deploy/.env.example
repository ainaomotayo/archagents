# =============================================================================
# SENTINEL Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all CHANGE_ME values before deploying.
#
# Usage:
#   cp deploy/.env.example deploy/.env
#   $EDITOR deploy/.env
#   docker compose -f docker-compose.yml -f deploy/docker-compose.production.yml \
#     --profile all-agents --profile sso --profile monitoring \
#     --env-file deploy/.env up -d
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sentinel:CHANGE_ME@postgres:5432/sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=sentinel

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API ──────────────────────────────────────────────────────────────────────
SENTINEL_SECRET=CHANGE_ME
NODE_ENV=production

# ── Dashboard ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://sentinel.example.com
NEXTAUTH_SECRET=CHANGE_ME

# ── GitHub OAuth (for dashboard login) ───────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub App (for bridge / webhooks) ───────────────────────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# ── GitLab OAuth (optional) ──────────────────────────────────────────────────
# GITLAB_CLIENT_ID=
# GITLAB_CLIENT_SECRET=
# GITLAB_URL=https://gitlab.com

# ── OIDC (optional) ─────────────────────────────────────────────────────────
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_ISSUER=
# OIDC_PROVIDER_NAME=SSO

# ── SAML / SSO (BoxyHQ Jackson) ─────────────────────────────────────────────
JACKSON_API_KEYS=
# SAML_JACKSON_URL=http://saml-jackson:5225
# SAML_JACKSON_PRODUCT=sentinel
# SAML_CLIENT_ID=dummy
# SAML_CLIENT_SECRET=dummy

# ── Cloud Storage (attestation archival — pick one provider) ─────────────────
# CLOUD_PROVIDER=                # aws | gcp | azure
# ARCHIVE_BUCKET=
# ARCHIVE_PREFIX=sentinel
# ARCHIVE_RETENTION_DAYS=2555

# AWS
# AWS_REGION=us-east-1
# S3_ARCHIVE_BUCKET=
# KMS_MASTER_KEY_ID=

# GCP
# GCP_PROJECT_ID=
# GCS_ARCHIVE_BUCKET=
# GCP_KMS_LOCATION=global
# GCP_KMS_KEY_RING=sentinel
# GCP_KMS_KEY_ID=sentinel-master

# Azure
# AZURE_STORAGE_ACCOUNT_URL=
# AZURE_ARCHIVE_CONTAINER=
# AZURE_KEY_VAULT_URL=
# AZURE_KEY_NAME=sentinel-master

# ── Monitoring ───────────────────────────────────────────────────────────────
# GF_SECURITY_ADMIN_PASSWORD=admin

# ── Nginx / TLS ─────────────────────────────────────────────────────────────
# NGINX_CONF=./deploy/nginx.conf
# TLS_CERT_PATH=./deploy/certs/fullchain.pem
# TLS_KEY_PATH=./deploy/certs/privkey.pem

# ── Scheduler ────────────────────────────────────────────────────────────────
# SELF_SCAN_ENABLED=true
# SCHEDULER_LEASE_TTL=15000
# SCAN_TIMEOUT_MS=300000
