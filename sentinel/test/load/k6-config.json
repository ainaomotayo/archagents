{
  "scenarios": {
    "smoke": {
      "description": "Quick smoke test with minimal load",
      "scenarios": {
        "scan_submissions": {
          "executor": "constant-vus",
          "vus": 5,
          "duration": "30s"
        }
      },
      "thresholds": {
        "http_req_duration": ["p(95)<3000"],
        "http_req_failed": ["rate<0.05"]
      }
    },
    "load": {
      "description": "Standard load test simulating normal traffic",
      "scenarios": {
        "scan_submissions": {
          "executor": "constant-vus",
          "vus": 100,
          "duration": "5m"
        },
        "poll_results": {
          "executor": "constant-vus",
          "vus": 50,
          "duration": "5m",
          "startTime": "30s"
        }
      },
      "thresholds": {
        "http_req_duration": ["p(95)<2000"],
        "http_req_failed": ["rate<0.01"],
        "checks": ["rate>0.99"]
      }
    },
    "stress": {
      "description": "Stress test to find breaking point",
      "scenarios": {
        "scan_submissions": {
          "executor": "ramping-vus",
          "startVUs": 0,
          "stages": [
            { "duration": "2m", "target": 100 },
            { "duration": "3m", "target": 200 },
            { "duration": "2m", "target": 500 },
            { "duration": "1m", "target": 0 }
          ]
        }
      },
      "thresholds": {
        "http_req_duration": ["p(95)<5000"],
        "http_req_failed": ["rate<0.10"]
      }
    },
    "soak": {
      "description": "Extended duration test to detect memory leaks",
      "scenarios": {
        "scan_submissions": {
          "executor": "constant-vus",
          "vus": 50,
          "duration": "30m"
        },
        "poll_results": {
          "executor": "constant-vus",
          "vus": 25,
          "duration": "30m",
          "startTime": "1m"
        }
      },
      "thresholds": {
        "http_req_duration": ["p(95)<2000"],
        "http_req_failed": ["rate<0.01"]
      }
    }
  },
  "defaults": {
    "baseUrl": "http://localhost:3000",
    "token": "test-token"
  }
}
